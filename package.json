{
  "name": "qwen-orchestrator",
  "version": "0.0.2",
  "description": "Enterprise-grade multi-agent orchestration extension for Qwen Code CLI — 22 agents, 26 skills, 6 commands, MCP Memory server",
  "type": "module",
  "author": "Omar-Obando",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Omar-Obando/qwen-orchestrator"
  },
  "scripts": {
    "install:mcp": "cd mcp-server && npm install",
    "build:mcp": "cd mcp-server && npm run build",
    "dev:mcp": "cd mcp-server && npx tsx src/index.ts",
    "setup": "npm run install:mcp && npm run build:mcp",
    "clean": "rm -rf mcp-server/node_modules mcp-server/dist",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "cd mcp-server && tsc --noEmit",
    "preflight": "npm run lint && npm run format:check && npm run typecheck"
  },
  "keywords": [
    "qwen-code",
    "qwen-code-extension",
    "multi-agent",
    "orchestration",
    "ai",
    "development",
    "tdd",
    "code-review",
    "devops"
  ],
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "prettier": "^3.0.0",
    "typescript": "~5.4.5"
  }
}
